{
  "name": "maushot",
  "version": "1.0.0",
  "description": "MauShot - A desktop screenshot application with annotation tools",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "keywords": [
    "screenshot",
    "electron",
    "desktop",
    "annotation"
  ],
  "author": {
    "name": "Maui Medrano"
  },
  "license": "MIT",
  "build": {
    "appId": "com.mauimedrano.maushot",
    "productName": "MauShot",
    "copyright": "Copyright © 2026 Maui Medrano",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "**/*",
      "!tests/**",
      "!*.bat",
      "!*.md"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "jimp": "^0.22.12"
  }
}
